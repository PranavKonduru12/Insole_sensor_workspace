#############################################
# Rule for re-running cmake.

rule RERUN_CMAKE
  command = C:\ncs\toolchains\dcbdc366a1\opt\bin\cmake.exe --regenerate-during-build -SC:\LocalWorkspace\Insole_sensor_workspace\peripheral_uart_file -BC:\LocalWorkspace\Insole_sensor_workspace\peripheral_uart_file\build\peripheral_uart_file
  description = Re-running CMake...
  generator = 1


#############################################
# Rule for cleaning additional files.

rule CLEAN_ADDITIONAL
  command = C:\ncs\toolchains\dcbdc366a1\opt\bin\cmake.exe -DCONFIG=$CONFIG -P CMakeFiles\clean_additional.cmake
  description = Cleaning additional files...


#############################################
# Rule for cleaning all built files.

rule CLEAN
  command = C:\ncs\toolchains\dcbdc366a1\opt\bin\ninja.exe $FILE_ARG -t clean $TARGETS
  description = Cleaning all built files...


#############################################
# Rule for printing all primary targets available.

rule HELP
  command = C:\ncs\toolchains\dcbdc366a1\opt\bin\ninja.exe -t targets
  description = All primary targets available:

